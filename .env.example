# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/meta_reklam_panel
DB_HOST=postgres
DB_PORT=5432
DB_USER=meta_panel_user
DB_PASSWORD=secure_password_123
DB_NAME=meta_reklam_panel

# Meta API Configuration
META_API_VERSION=v18.0
META_ACCESS_TOKEN=your_meta_access_token_here
META_BUSINESS_ACCOUNT_ID=your_business_account_id

# Antigravity Integration
ANTIGRAVITY_API_KEY=your_antigravity_api_key
ANTIGRAVITY_API_URL=https://api.antigravity.dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_password

# Logging
LOG_LEVEL=info

# Redis (for real-time updates)
REDIS_URL=redis://localhost:6379

# Frontend
REACT_APP_API_URL=http://localhost:5000/api
